# ── Python ──────────────────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
.pytest_cache/

# ── Node / frontend ─────────────────────────────────────────────────────
node_modules/
# frontend/build/ is regenerated by `npm run deploy` (gh-pages -d build)
frontend/build/

# ── Secrets / env ───────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Geospatial + large data (fetched/generated at runtime) ──────────────
data/
*.tif
*.gpkg
*.pbf
*.osm
*.geojson
*.shp
*.db

# ── Build / archive / report artifacts ──────────────────────────────────
*.tar.gz
*.pdf
ouputs/
extract_boundaries.py

# ── Local-only task tracking (never commit) ─────────────────────────────
taskboard.csv
taskboard.md

# ── Windows "mark of the web" artifacts ─────────────────────────────────
# Match any separator before the suffix: these files use a Unicode colon
# (U+F03A), not an ASCII ':', so an explicit ':Zone.Identifier' never matched.
*Zone.Identifier

# ── Keep: committed reference docs / assets ─────────────────────────────
!data/rag_docs/
!data/rag_docs/*.txt
!data/rag_docs/*.md
